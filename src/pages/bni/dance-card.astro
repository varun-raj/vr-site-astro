---
import Main from "../../layouts/Main.astro";
import bniData from "../../content/bni.json";
---

<Main
  meta={{
    title: `BNI Dance Card | ${bniData.profile.name}`,
    description: `One-to-One preparation for ${bniData.profile.name}, ${bniData.profile.role}.`,
    image: "/assets/og-images/dance-card.png",
    noindex: true,
  }}
>
  <div class="max-w-3xl mx-auto space-y-24 pt-8 pb-24">
    {/* Clean, Approachable Header */}
    <header class="flex flex-col md:flex-row gap-10 items-start md:items-center justify-between border-b border-zinc-100 dark:border-zinc-900 pb-12">
      <div class="space-y-6">
        <img 
          src="/bni-logo.png" 
          alt="BNI Logo" 
          class="h-12 w-auto"
        />
        <div class="space-y-2">
          <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
            {bniData.profile.name}
          </h1>
          <div class="flex flex-wrap gap-x-4 gap-y-2 text-lg text-zinc-600 dark:text-zinc-400 font-medium">
            <span>{bniData.profile.role}</span>
            <span class="text-zinc-300 dark:text-zinc-700 hidden md:inline">|</span>
            <span class="text-[#CF202E]">{bniData.profile.category}</span>
          </div>
          <p class="text-base font-medium text-zinc-500 dark:text-zinc-500 uppercase tracking-widest">
            BNI {bniData.profile.chapter} Chapter
          </p>
          <p class="text-lg text-zinc-400 dark:text-zinc-500 italic leading-relaxed pt-2">
            "{bniData.profile.tagline}"
          </p>
        </div>
      </div>
      <img
        src={bniData.profile.image}
        width={160}
        height={160}
        class="size-32 md:size-40 bg-zinc-100 object-cover dark:bg-zinc-800 rounded-3xl shadow-xl border-4 border-white dark:border-zinc-900"
        alt={bniData.profile.name}
      />
    </header>

    {/* Section 1: Getting to Know Me (GAINS) */}
    <section class="space-y-12">
      <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 flex items-center gap-3">
        <span class="text-zinc-300 dark:text-zinc-700">01</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-zinc-400"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        My Profile
      </h2>
      
      <div class="space-y-16">
        {bniData.gains.map((item) => (
          <div class="space-y-4">
            <h3 class="text-xs uppercase tracking-[0.2em] font-bold text-[#CF202E] flex items-center gap-2">
              {item.label === "Goals" && <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-zinc-400"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>}
              {item.label === "Accomplishments" && <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-zinc-400"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>}
              {item.label === "Interests" && <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-zinc-400"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>}
              {item.label === "Networks" && <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-zinc-400"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>}
              {item.label === "Skills" && <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-zinc-400"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a2 2 0 0 1-2.14-1.95 2 2 0 0 1 2.14-1.95l-.3 1.15a1 1 0 0 1-1.39.63l-1.03-.43a1 1 0 0 0-1.28.46l-2.91 2.91Z"/><path d="m14.7 6.3 5.3 5.3"/><path d="M11 10 3 18l1.5 1.5 8-8"/><path d="m11 10 3.7 3.7a1 1 0 0 0 1.4 0l1.6-1.6a1 1 0 0 0 0-1.4L14 7"/></svg>}
              {item.label}
            </h3>
            <p class="text-lg leading-relaxed text-zinc-700 dark:text-zinc-300">
              {item.content}
            </p>
          </div>
        ))}
      </div>
    </section>

    {/* Section 2: How I Can Help (Superpowers) */}
    <section class="space-y-12 bg-zinc-50 dark:bg-zinc-900/50 -mx-6 px-6 py-16 rounded-[2rem] border border-zinc-100 dark:border-zinc-900">
      <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 flex items-center gap-3">
        <span class="text-zinc-300 dark:text-zinc-700">02</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-zinc-400"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="m5 3 1 1"/><path d="m19 17 1 1"/><path d="M21 3l-1 1"/><path d="m5 17-1 1"/></svg>
        How I Can Help
      </h2>

      <div class="space-y-12">
        {bniData.superpowers.map((sp) => (
          <div class="space-y-3">
            <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-100">{sp.title}</h3>
            <p class="text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed">{sp.description}</p>
          </div>
        ))}
      </div>
    </section>

    {/* Section 3: Listening for Referrals */}
    <section class="space-y-12">
      <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 flex items-center gap-3">
        <span class="text-zinc-300 dark:text-zinc-700">03</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-zinc-400"><path d="m3 11 18-5v12L3 13v-2Z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>
        When to Think of Me
      </h2>

      <div class="space-y-6">
        <p class="text-zinc-500 dark:text-zinc-400 text-lg">If you hear a friend or client say things like these, I'd love an introduction:</p>
        <div class="space-y-4">
          {bniData.referrals.triggers.map((trigger) => (
            <div class="flex gap-4 p-5 rounded-2xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-100 dark:border-zinc-900 group transition-colors hover:border-zinc-200 dark:hover:border-zinc-800">
              <div class="shrink-0 mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#CF202E] opacity-70 group-hover:opacity-100 transition-opacity"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <p class="text-lg text-zinc-700 dark:text-zinc-300 font-medium leading-relaxed">
                {trigger}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Section 4: Ideal Partners & CTA */}
    <section class="space-y-12 border-t border-zinc-100 dark:border-zinc-900 pt-16">
      <div class="space-y-8">
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 flex items-center gap-3">
          <span class="text-zinc-300 dark:text-zinc-700">04</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-zinc-400"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Who I'm Looking For
        </h2>
        <div class="flex flex-wrap gap-4">
          {bniData.referrals.ideal_partners.map((partner) => (
            <span class="px-6 py-3 rounded-2xl bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100 text-base font-medium">
              {partner}
            </span>
          ))}
        </div>
      </div>

      <div class="mt-16 bg-[#CF202E] p-12 rounded-[2.5rem] text-white space-y-8 shadow-2xl shadow-red-500/20">
        <div class="space-y-2">
          <p class="text-xs uppercase tracking-[0.2em] font-bold opacity-80">Next Steps</p>
          <h2 class="text-4xl font-bold tracking-tight">Let's Connect</h2>
        </div>
        <p class="text-xl opacity-90 max-w-md leading-relaxed">
          I'd love to learn more about your business and how I can help you find more referrals.
        </p>
        <a 
          href={`mailto:${bniData.profile.email}?subject=BNI 1-to-1 Meeting Request`}
          class="inline-flex items-center gap-3 px-8 py-4 bg-white text-[#CF202E] rounded-2xl text-lg font-bold hover:scale-105 transition-transform duration-300 no-underline shadow-lg"
        >
          Schedule a 1-to-1
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <footer class="pt-12 border-t border-zinc-100 dark:border-zinc-900 text-center space-y-6">
      <div class="flex flex-col items-center gap-4">
        <img src="/bni-logo.png" alt="BNI" class="h-10 mx-auto transition-transform hover:scale-105 duration-300" />
        <p class="text-zinc-500 dark:text-zinc-400 text-sm font-medium uppercase tracking-widest">
          FoundrySoft · BNI 1-to-1 Preparation
        </p>
      </div>
      <div class="bg-zinc-50 dark:bg-zinc-900/50 inline-block px-4 py-1.5 rounded-full text-[10px] font-mono text-zinc-400 uppercase tracking-tighter">
        Galaxy Chapter · Web Development Category
      </div>
    </footer>
  </div>
</Main>
