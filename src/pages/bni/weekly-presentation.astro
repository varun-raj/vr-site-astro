---
import Main from "../../layouts/Main.astro";
import bniData from "../../content/bni.json";
import variants from "../../content/bni-variants.json";

type Block = { kind: "para" | "punch" | "signoff"; lines: string[] };
type Variant = {
  id: string;
  title: string;
  focus: string;
  duration: string;
  blocks: Block[];
};
---

<Main
  meta={{
    title: `Weekly Presentations | ${bniData.profile.name}`,
    description: `30-second BNI weekly presentation variants for ${bniData.profile.name}.`,
    image: "/bni-og.png",
    noindex: true,
  }}
>
  <div class="full-bleed px-6 md:px-12 pt-12 pb-24 space-y-16">
    {/* Header */}
    <header class="max-w-4xl space-y-6 border-b border-zinc-900 pb-12">
      <div class="flex items-center gap-4">
        <img src="/bni-logo.png" alt="BNI Logo" class="h-10 w-auto" />
        <div class="h-6 w-px bg-zinc-800"></div>
        <p class="text-xs uppercase tracking-[0.3em] font-mono text-zinc-500">
          Internal Resources
        </p>
      </div>
      
      <div class="space-y-2">
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-100 italic">
          30-Second <span class="text-[#CF202E]">Weekly Intros</span>
        </h1>
        <p class="text-lg text-zinc-400 max-w-2xl leading-relaxed">
          Five rotation-ready scripts tailored for the <span class="text-zinc-200 font-medium">{bniData.profile.category}</span> category. 
          Focusing on trust, speed, and results for ambitious founders.
        </p>
      </div>

      <div class="flex flex-wrap gap-4 pt-2">
        <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900 border border-zinc-800 text-[10px] font-mono uppercase tracking-widest text-zinc-400">
          <span class="size-1.5 rounded-full bg-green-500 animate-pulse"></span>
          {bniData.profile.chapter} Chapter
        </div>
        <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900 border border-zinc-800 text-[10px] font-mono uppercase tracking-widest text-zinc-400">
          5 Variants Ready
        </div>
      </div>
    </header>

    {/* Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {variants.map((variant) => (
        <div
          class="variant-card group relative bg-zinc-950 border border-zinc-800 rounded-[2rem] overflow-hidden flex flex-col hover:border-[#CF202E]/50 transition-all duration-300"
        >
          {/* Card Top Label */}
          <div class="flex items-center justify-between p-6 pb-0">
            <div class="flex items-center gap-3 font-mono text-[10px] uppercase tracking-widest">
              <span class="text-[#CF202E] font-bold">#{variant.id}</span>
              <span class="text-zinc-700">/</span>
              <span class="text-zinc-500">{variant.duration}</span>
            </div>
            <button 
              class="copy-btn size-8 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 hover:text-white hover:bg-[#CF202E] transition-all"
              data-variant-id={variant.id}
              title="Copy to clipboard"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </button>
          </div>

          {/* Main Focus */}
          <div class="p-6 pt-4 flex-1 space-y-6">
            <h2 class="text-2xl font-bold tracking-tight text-zinc-100 group-hover:text-[#CF202E] transition-colors">
              {variant.focus}
            </h2>

            <div class="space-y-4 script-content">
              {variant.blocks.map((block) => {
                if (block.kind === "punch") {
                  return (
                    <div class="space-y-1">
                      {block.lines.map((line) => (
                        <p class="text-sm italic text-zinc-100 leading-relaxed">
                          {line}
                        </p>
                      ))}
                    </div>
                  );
                }
                if (block.kind === "signoff") {
                  return (
                    <div class="pt-2 space-y-1">
                      {block.lines.map((line) => (
                        <p class="text-sm font-bold text-zinc-100 italic leading-relaxed">
                          {line}
                        </p>
                      ))}
                    </div>
                  );
                }
                return (
                  <div class="space-y-1">
                    {block.lines.map((line) => (
                      <p class="text-sm text-zinc-400 leading-relaxed">
                        {line}
                      </p>
                    ))}
                  </div>
                );
              })}
            </div>
          </div>

          {/* Card Footer */}
          <div class="p-6 pt-0 mt-auto">
            <button
              type="button"
              data-variant-trigger={variant.id}
              class="w-full mt-6 py-3 rounded-xl bg-[#CF202E] border border-[#CF202E]/20 text-[10px] font-mono uppercase tracking-[0.2em] font-bold text-white hover:bg-[#b01b27] hover:scale-[1.02] active:scale-[0.98] transition-all shadow-lg shadow-red-900/20"
            >
              Practice →
            </button>
          </div>
        </div>
      ))}
    </div>

    {/* Footer */}
    <footer class="pt-12 border-t border-zinc-900 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
      <div class="space-y-4">
        <img src="/bni-logo.png" alt="BNI" class="h-8 opacity-50 grayscale hover:grayscale-0 transition-all" />
        <p class="text-zinc-600 text-[10px] font-mono uppercase tracking-[0.2em]">
          FoundrySoft · BNI {bniData.profile.chapter}
        </p>
      </div>
      <div class="flex gap-4">
        <a href="/bni/dance-card" class="text-xs font-mono uppercase tracking-widest text-zinc-500 hover:text-[#CF202E] transition-colors">
          Dance Card
        </a>
        <span class="text-zinc-800">/</span>
        <a href="/about" class="text-xs font-mono uppercase tracking-widest text-zinc-500 hover:text-[#CF202E] transition-colors">
          About Varun
        </a>
      </div>
    </footer>
  </div>

  {/* Modals */}
  {variants.map((variant) => (
    <dialog id={`dialog-${variant.id}`} class="variant-dialog">
      <div class="dialog-inner">
        <div class="dialog-header">
          <div class="flex-1 flex items-center justify-between font-mono text-xs uppercase tracking-[0.2em] min-w-0 pr-6 md:pr-12">
            <div class="flex items-center gap-4">
              <div class="flex items-center gap-2">
                <span class="text-[#CF202E] font-bold">{variant.id}</span>
                <span class="text-zinc-700">/</span>
                <span class="text-zinc-500">{variant.duration}</span>
              </div>
              <div class="h-4 w-px bg-zinc-800"></div>
              <p class="text-[10px] text-zinc-500 hidden sm:block">Practice Mode</p>
            </div>
            <div class="timer-display text-zinc-100 font-bold tabular-nums bg-zinc-900 px-3 py-1 rounded-md border border-zinc-800">00:30</div>
          </div>
          <button
            type="button"
            data-dialog-close={variant.id}
            aria-label="Close"
            class="size-10 rounded-full bg-zinc-900 border border-zinc-800 hover:border-[#CF202E] text-zinc-100 flex items-center justify-center transition-all cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>

        {/* Progress Bar */}
        <div class="h-1 bg-zinc-900 w-full overflow-hidden">
          <div class="progress-bar h-full bg-[#CF202E] w-0 transition-all duration-300"></div>
        </div>

        <div class="dialog-body relative select-none" data-teleprompter data-duration="30">
          {/* Vertical Timer Track */}
          <div class="fixed left-2 md:left-4 top-1/4 bottom-1/4 w-1 bg-zinc-900 rounded-full overflow-hidden">
            <div class="vertical-timer-bar w-full bg-[#CF202E] h-0 transition-all duration-1000 ease-linear"></div>
          </div>

          {/* Dedicated Play Button (Bottom Right) — Upgraded */}
          <div class="fixed bottom-8 right-8 z-50 flex items-center justify-center">
            <button 
              type="button"
              class="start-overlay relative size-16 md:size-20 rounded-full bg-zinc-950 border border-zinc-800 flex items-center justify-center transition-all duration-500 hover:border-[#CF202E]/50 group"
            >
              {/* Progress Ring (SVG) */}
              <svg class="absolute inset-0 size-full -rotate-90" viewBox="0 0 100 100">
                <circle
                  cx="50" cy="50" r="46"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="text-zinc-900"
                />
                <circle
                  cx="50" cy="50" r="46"
                  fill="none"
                  stroke="#CF202E"
                  stroke-width="3"
                  stroke-dasharray="289"
                  stroke-dashoffset="289"
                  class="progress-ring-circle transition-all duration-1000 ease-linear"
                />
              </svg>

              {/* Inner Red Core */}
              <div class="size-10 md:size-12 rounded-full bg-[#CF202E] flex items-center justify-center shadow-[0_0_20px_rgba(207,32,46,0.3)] group-hover:shadow-[0_0_40px_rgba(207,32,46,0.5)] group-hover:scale-105 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-white fill-white play-icon"><path d="m7 3 14 9-14 9V3z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-white hidden reset-icon"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              </div>

              {/* Orbital Label (Static) */}
              <div class="absolute -inset-4 pointer-events-none ready-label-container">
                <div class="h-full w-full flex items-start justify-center">
                   <span class="text-[8px] font-mono font-bold tracking-[0.3em] text-[#CF202E] uppercase bg-black px-2 py-0.5 rounded-full border border-zinc-800 ready-label">PLAY</span>
                </div>
              </div>
            </button>
          </div>

          <div class="mb-10 md:mb-16">
            <h2 class="text-3xl md:text-7xl font-bold tracking-tight text-zinc-100 italic leading-tight">
              {variant.focus}
            </h2>
            <p class="text-[10px] md:text-xs font-mono uppercase tracking-[0.2em] text-zinc-600 mt-4">
              Tap red button to start 30s timer
            </p>
          </div>

          <div class="space-y-8 md:space-y-16">
            {variant.blocks.map((block) => {
              if (block.kind === "punch") {
                return (
                  <div class="space-y-2">
                    {block.lines.map((line) => (
                      <p class="text-xl md:text-5xl italic font-medium leading-tight">
                        {line.split(" ").map((word, i, arr) => (
                          <>
                            <span class="word text-white transition-all duration-200 inline-block">{word}</span>
                            {i < arr.length - 1 && " "}
                          </>
                        ))}
                      </p>
                    ))}
                  </div>
                );
              }
              if (block.kind === "signoff") {
                return (
                  <div class="pt-4 space-y-2">
                    {block.lines.map((line) => (
                      <p class="text-lg md:text-3xl font-bold leading-relaxed italic">
                        {line.split(" ").map((word, i, arr) => (
                          <>
                            <span class="word text-white transition-all duration-200 inline-block">{word}</span>
                            {i < arr.length - 1 && " "}
                          </>
                        ))}
                      </p>
                    ))}
                  </div>
                );
              }
              return (
                <div class="space-y-2">
                  {block.lines.map((line) => (
                    <p class="text-lg md:text-4xl leading-relaxed font-medium">
                      {line.split(" ").map((word, i, arr) => (
                        <>
                          <span class="word text-white transition-all duration-200 inline-block">{word}</span>
                          {i < arr.length - 1 && " "}
                        </>
                      ))}
                    </p>
                  ))}
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </dialog>
  ))}

  <style is:global>
    .word {
      transition: all 0.2s ease;
    }
    .word.idle {
      color: #fff !important;
      opacity: 0.1 !important;
    }
    .word.active {
      color: #fff !important;
      opacity: 1 !important;
      transform: scale(1.05);
    }
    .word.past {
      color: #fff !important;
      opacity: 0.3 !important;
      transform: scale(1);
    }
    @keyframes spin-slow {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    .animate-spin-slow {
      animation: spin-slow 8s linear infinite;
    }
    .full-bleed {
      width: 100vw;
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      max-width: 100vw;
    }
    .variant-dialog {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      max-width: 100vw;
      max-height: 100vh;
      margin: 0;
      padding: 0;
      border: none;
      background: transparent;
      color: #f4f4f5;
    }
    .variant-dialog::backdrop {
      background: rgba(0, 0, 0, 0.95);
      backdrop-filter: blur(12px);
    }
    .variant-dialog .dialog-inner {
      position: relative;
      width: 100%;
      height: 100%;
      background: #000;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .variant-dialog .dialog-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 2rem;
      background: black;
      border-bottom: 1px solid #111;
    }
    .variant-dialog .dialog-body {
      padding: 4rem 2rem;
      overflow-y: auto;
      width: 100%;
      flex: 1;
    }
    @media (min-width: 768px) {
      .variant-dialog .dialog-body {
        padding: 6rem 8rem;
      }
    }
    body:has(.variant-dialog[open]) {
      overflow: hidden;
    }
  </style>

  <script>
    // Dialog triggers
    const triggerButtons = document.querySelectorAll<HTMLButtonElement>("[data-variant-trigger]");
    triggerButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.variantTrigger;
        const dialog = document.getElementById(`dialog-${id}`) as HTMLDialogElement | null;
        dialog?.showModal();
      });
    });

    // Dialog closers
    const closeButtons = document.querySelectorAll<HTMLButtonElement>("[data-dialog-close]");
    closeButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.dialogClose;
        const dialog = document.getElementById(`dialog-${id}`) as HTMLDialogElement | null;
        dialog?.close();
      });
    });

    // Close on backdrop click
    document.querySelectorAll<HTMLDialogElement>(".variant-dialog").forEach((dialog) => {
      dialog.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
      });
    });

    // Teleprompter Logic
    function initTeleprompter() {
      const containers = document.querySelectorAll<HTMLElement>("[data-teleprompter]");
      
      containers.forEach((container) => {
        const dialog = container.closest("dialog") as HTMLDialogElement;
        const words = container.querySelectorAll<HTMLElement>(".word");
        const progressBar = dialog.querySelector(".progress-bar") as HTMLElement;
        const progressRing = dialog.querySelector(".progress-ring-circle") as SVGCircleElement;
        const verticalTimerBar = dialog.querySelector(".vertical-timer-bar") as HTMLElement;
        const startOverlay = dialog.querySelector(".start-overlay") as HTMLElement;
        const timerDisplay = dialog.querySelector(".timer-display") as HTMLElement;
        const statusIndicator = dialog.querySelector(".status-indicator") as HTMLElement;
        const playIcon = dialog.querySelector(".play-icon") as SVGElement;
        const resetIcon = dialog.querySelector(".reset-icon") as SVGElement;
        const readyLabel = dialog.querySelector(".ready-label") as HTMLElement;
        
        let currentIndex = -1;
        let isRunning = false;
        let timerInterval: ReturnType<typeof setInterval> | null = null;
        let teleInterval: ReturnType<typeof setInterval> | null = null;
        const totalDurationSecs = parseInt(container.dataset.duration || "30");
        const totalDuration = totalDurationSecs * 1000;
        const wordInterval = totalDuration / words.length;

        const updateHighlight = () => {
          words.forEach((word, index) => {
            word.classList.remove("active", "past", "idle");
            if (!isRunning && currentIndex === -1) {
              return;
            }

            if (index === currentIndex) {
              word.classList.add("active");
              word.scrollIntoView({ behavior: "smooth", block: "center" });
            } else if (index < currentIndex) {
              word.classList.add("past");
            } else {
              word.classList.add("idle");
            }
          });

          if (progressBar) {
            const progress = ((currentIndex + 1) / words.length) * 100;
            progressBar.style.width = `${progress}%`;
          }
        };

        const updateProgressRing = (remainingSecs: number) => {
          if (progressRing) {
            const total = totalDurationSecs;
            const dashArray = 289;
            const offset = dashArray - ((total - remainingSecs) / total) * dashArray;
            progressRing.style.strokeDashoffset = offset.toString();
          }
        };

        const stop = () => {
          isRunning = false;
          if (timerInterval) clearInterval(timerInterval);
          if (teleInterval) clearInterval(teleInterval);
          if (statusIndicator) {
            statusIndicator.innerHTML = `<span class="size-1.5 rounded-full bg-zinc-800"></span> Stopped`;
          }
          if (verticalTimerBar) verticalTimerBar.style.height = "100%";
          if (playIcon) playIcon.classList.add("hidden");
          if (resetIcon) resetIcon.classList.remove("hidden");
          if (readyLabel) readyLabel.classList.add("hidden");
          updateHighlight();
        };

        const reset = () => {
          stop();
          currentIndex = -1;
          if (timerDisplay) timerDisplay.innerText = `00:${container.dataset.duration}`;
          if (progressBar) progressBar.style.width = "0%";
          if (progressRing) {
            progressRing.style.transition = "none";
            progressRing.style.strokeDashoffset = "289";
          }
          if (verticalTimerBar) {
            verticalTimerBar.style.transition = "none";
            verticalTimerBar.style.height = "0%";
          }
          if (startOverlay) {
            startOverlay.style.opacity = "1";
            startOverlay.style.pointerEvents = "auto";
          }
          if (playIcon) playIcon.classList.remove("hidden");
          if (resetIcon) resetIcon.classList.add("hidden");
          if (readyLabel) readyLabel.classList.remove("hidden");
          if (statusIndicator) {
            statusIndicator.innerHTML = `<span class="size-1.5 rounded-full bg-zinc-800"></span> Ready`;
          }
          updateHighlight();
        };

        const start = () => {
          if (isRunning) return;
          isRunning = true;
          currentIndex = 0;

          if (verticalTimerBar) {
            verticalTimerBar.style.transition = `height ${totalDurationSecs}s linear`;
            verticalTimerBar.style.height = "100%";
          }

          if (progressRing) {
            progressRing.style.transition = `stroke-dashoffset ${totalDurationSecs}s linear`;
            progressRing.style.strokeDashoffset = "0";
          }

          if (statusIndicator) {
            statusIndicator.innerHTML = `<span class="size-1.5 rounded-full bg-green-500 animate-pulse"></span> Presenting`;
          }

          if (readyLabel) readyLabel.classList.add("hidden");
          if (playIcon) playIcon.classList.add("hidden");
          if (resetIcon) resetIcon.classList.add("hidden");

          updateHighlight();

          let remaining = totalDurationSecs;
          timerInterval = setInterval(() => {
            remaining--;
            if (timerDisplay) {
              timerDisplay.innerText = `00:${remaining.toString().padStart(2, '0')}`;
            }
            if (remaining <= 0) stop();
          }, 1000);

          teleInterval = setInterval(() => {
            currentIndex++;
            if (currentIndex >= words.length) {
              stop();
            } else {
              updateHighlight();
            }
          }, wordInterval);
        };

        // Only start via the overlay button
        if (startOverlay) {
          startOverlay.addEventListener("click", (e) => {
            e.stopPropagation();
            start();
          });
        }

        // Prevent general clicks from advancing
        container.addEventListener("click", (e) => {
          if (!isRunning && e.target === startOverlay) return; 
          e.stopPropagation();
        });

        dialog?.addEventListener("close", reset);
      });
    }

    // Run on load
    initTeleprompter();

    // If using view transitions, run on swap
    document.addEventListener("astro:after-swap", initTeleprompter);

    // Copy functionality
    const copyButtons = document.querySelectorAll<HTMLButtonElement>(".copy-btn");
    copyButtons.forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const card = btn.closest('.variant-card');
        if (!card) return;
        
        const content = card.querySelector('.script-content');
        const signoff = card.querySelector('.border-t p');
        
        let text = "";
        if (content) text += content.textContent?.trim().replace(/\s+/g, ' ') + "\n\n";
        if (signoff) text += signoff.textContent?.trim();
        
        navigator.clipboard.writeText(text.trim()).then(() => {
          const originalInner = btn.innerHTML;
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
          btn.classList.add('bg-green-600', 'text-white', 'border-green-500');
          
          setTimeout(() => {
            btn.innerHTML = originalInner;
            btn.classList.remove('bg-green-600', 'text-white', 'border-green-500');
          }, 2000);
        });
      });
    });
  </script>
</Main>
