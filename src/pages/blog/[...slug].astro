---
import { type CollectionEntry, getCollection } from "astro:content";
// @ts-ignore
import { render } from "astro:content";
import Main from "../../layouts/Main.astro";
import { AppConfig } from "../../config/AppConfig";
import { format } from "date-fns";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);
---

<Main
  meta={{
    title: `${post.data.title} | ${AppConfig.title}`,
    description: post.data.description,
    image: post.data.cover || "/assets/og-images/blog.png",
  }}
>
  <div class="space-y-8">
    <div class="flex items-center justify-between border-b border-zinc-900 pb-4">
      <a href="/blog" class="group flex items-center gap-2 font-mono text-xxxs uppercase tracking-widest text-zinc-500 hover:text-zinc-100 transition-colors !no-underline">
        <span class="text-emerald-500 group-hover:animate-pulse">←</span>
        RETURN_TO_ARCHIVE
      </a>
      
      <div class="font-mono text-xxxs text-zinc-700 uppercase tracking-widest hidden sm:block">
        ID: {post.id.slice(0, 8)} | STATUS: READ_ONLY
      </div>
    </div>

    <header class="space-y-4">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-100 uppercase font-mono">
        <span class="text-emerald-500 mr-2">></span>{post.data.title}
      </h1>

      <div class="flex items-center gap-4 font-mono text-xxs text-zinc-500 uppercase tracking-widest">
        <time datetime={post.data.pubDate.toISOString()}>
          [{format(post.data.pubDate, 'yyyy-MM-dd')}]
        </time>
        <span>•</span>
        <span>Varun Raj</span>
      </div>
    </header>

    {post.data.cover && (
      <div class="aspect-video w-full overflow-hidden rounded-xl border border-zinc-900 bg-zinc-900/50">
        <img 
          src={post.data.cover} 
          alt={post.data.title}
          class="h-full w-full object-cover opacity-80"
        />
      </div>
    )}

    <article class="prose prose-invert prose-zinc max-w-none 
      prose-headings:font-mono prose-headings:uppercase prose-headings:tracking-tight
      prose-a:text-emerald-400 prose-a:no-underline hover:prose-a:underline
      prose-code:text-zinc-300 prose-code:bg-zinc-900 prose-code:px-1 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-zinc-900/50 prose-pre:border prose-pre:border-zinc-800
      prose-img:rounded-xl prose-img:border prose-img:border-zinc-900">
      <Content />
    </article>

    <footer class="mt-16 pt-8 border-t border-zinc-900">
      <div class="p-6 rounded-lg border border-dashed border-zinc-800 bg-zinc-900/30 text-center space-y-4">
        <p class="font-mono text-xxxs uppercase tracking-widest text-zinc-500">
          // End of transmission. 
        </p>
        <a href="/blog" class="inline-block px-4 py-2 bg-zinc-100 text-black font-mono text-xxxs uppercase tracking-widest hover:bg-white transition-colors rounded">
          Close_Log
        </a>
      </div>
    </footer>
  </div>
</Main>