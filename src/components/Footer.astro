---
import { AppConfig } from "../config/AppConfig";
---

<footer class="py-8 border-t border-zinc-100 dark:border-zinc-900 mt-12">
	<div class="flex flex-col md:flex-row items-start justify-between gap-6">
		<ul class="flex flex-wrap items-center gap-6 font-mono text-xxs uppercase tracking-widest">
			<li>
				<a
					class="plain text-zinc-400 hover:text-zinc-600 dark:text-zinc-500 dark:hover:text-zinc-300 flex items-center"
					href="/press-kit"
				>
					<span class="text-[10px] opacity-50 mr-1.5">[PK]</span> Press Kit
				</a>
			</li>
			<li>
				<a
					class="plain text-zinc-400 hover:text-zinc-600 dark:text-zinc-500 dark:hover:text-zinc-300 flex items-center"
					href="https://skcript.com"
					target="_blank"
				>
					<span class="text-[10px] opacity-50 mr-1.5">[SC]</span> Skcript
				</a>
			</li>
			<li>
				<a
					class="plain text-zinc-400 hover:text-zinc-600 dark:text-zinc-500 dark:hover:text-zinc-300 flex items-center"
					href="/projects"
				>
					<span class="text-[10px] opacity-50 mr-1.5">[PR]</span> Projects
				</a>
			</li>
		</ul>
		<p class="font-mono text-xxs text-zinc-400 dark:text-zinc-500 uppercase tracking-widest">
			&copy; {new Date().getFullYear()} {AppConfig.site_name}
		</p>
	</div>
</footer>

{(process.env.NODE_ENV === "production") && (
	<script is:inline>
		(function(c,l,a,r,i,t,y){
                      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
                  })(window, document, "clarity", "script", "hwwxk8x5mz");
	</script>
)}