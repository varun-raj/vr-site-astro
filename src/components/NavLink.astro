---
import clsx from 'clsx';

interface Props {
  href: string;
  isExact?: boolean;
  class?: string;
}

const { href, isExact = false, class: className, ...props } = Astro.props;
const { pathname } = Astro.url;

const isActive = isExact 
  ? pathname === href
  : pathname === href || (href !== '/' && pathname.startsWith(href));

const target = typeof href === 'string' && href.startsWith('http') 
  ? '_blank' 
  : undefined;
---

<a
  href={href}
  target={target}
  class={clsx(
    'plain relative block py-0.5 px-2 transition-colors font-mono text-xxs uppercase tracking-widest group overflow-hidden',
    isActive
      ? 'text-zinc-100 hover:text-black'
      : 'text-zinc-500 hover:text-black',
    className
  )}
  {...props}
>
  <span class="relative z-10 flex items-center">
    <span class="relative">
      <slot />
      <span class="absolute right-0 -bottom-0.5 w-2 h-0.5 bg-current hidden group-hover:block animate-terminal-cursor"></span>
    </span>
  </span>
  
  <span class="absolute inset-0 bg-zinc-100 transform -translate-x-[101%] group-hover:translate-x-0 transition-transform duration-200 ease-out"></span>

  {isActive && (
    <span class="absolute bottom-0 left-2 h-px w-2 bg-zinc-100 group-hover:opacity-0 transition-opacity"></span>
  )}
</a>
