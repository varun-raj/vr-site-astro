<!-- No frontmatter needed -->

<div id="ascii-modal" class="fixed inset-0 z-[300] bg-black/60 backdrop-blur-[2px] hidden items-center justify-center p-6 text-zinc-400 font-mono">
  <div class="w-full max-w-lg border-2 border-zinc-100 bg-black p-1 shadow-2xl">
    <div class="border border-zinc-100/30 p-4 space-y-4 relative">
      <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-black px-4 text-xs font-bold uppercase tracking-[0.2em] text-zinc-100">
        [ ascii_v1.0 ]
      </div>

      <div class="flex items-center justify-center pt-2">
        <pre class="text-emerald-500 font-mono text-xs md:text-sm select-none leading-tight"><code>{`    ╔══════════════════════╗
    ║  > hello, world_     ║
    ║                      ║
    ║  varun@terminal ~    ║
    ║  $ building things   ║
    ║  $ breaking things   ║
    ║  $ fixing things     ║
    ║  $ repeat            ║
    ║                      ║
    ╚══════════════════════╝
          │││  ┃┃
     ┌────┘│└────┐
     │  ╔══╧══╗  │
     │  ║ ☰☰☰ ║  │
     └──╚═════╝──┘`}</code></pre>
      </div>

      <div class="pt-2 border-t border-zinc-100/20 flex justify-center items-center text-[10px] uppercase font-bold">
        <span class="text-zinc-100 animate-pulse">Press [ESC] to Exit</span>
      </div>
    </div>
  </div>
</div>

<script>
  const modalEl = document.getElementById('ascii-modal')!;

  function isModalVisible() {
    return !modalEl.classList.contains('hidden');
  }

  function handleAsciiKeys(e: KeyboardEvent) {
    if (!isModalVisible()) return;

    if (e.key === 'Escape') {
      (window as any).toggleAscii();
      e.preventDefault();
      e.stopPropagation();
      return;
    }

    // Capture all keys while modal is open to prevent background interaction
    e.preventDefault();
    e.stopPropagation();
  }

  document.addEventListener('keydown', handleAsciiKeys, true);

  (window as any).toggleAscii = function () {
    const isHidden = modalEl.classList.contains('hidden');
    modalEl.classList.toggle('hidden');
    modalEl.classList.toggle('flex');
    document.body.style.overflow = isHidden ? 'hidden' : '';
  };
</script>
