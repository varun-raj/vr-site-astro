<!-- No frontmatter needed -->

<div id="mem-modal" class="fixed inset-0 z-[300] bg-black/60 backdrop-blur-[2px] hidden items-center justify-center p-6 text-zinc-400 font-mono">
  <div class="w-full max-w-md border-2 border-zinc-100 bg-black p-1 shadow-2xl">
    <div class="border border-zinc-100/30 p-4 space-y-4 relative">
      <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-black px-4 text-xs font-bold uppercase tracking-[0.2em] text-zinc-100">
        [ mem_v1.0 ]
      </div>

      <div id="mem-grid" class="select-none pt-2 flex items-center justify-center">
        <!-- Grid rendered by JS -->
      </div>

      <div id="mem-overlay" class="absolute inset-0 flex items-center justify-center pointer-events-none hidden">
        <div id="mem-overlay-text" class="text-center space-y-2 bg-black/80 px-6 py-4"></div>
      </div>

      <div class="pt-2 border-t border-zinc-100/20 flex justify-between items-center text-[10px] uppercase font-bold">
        <span class="text-zinc-500">Moves: <span id="mem-moves-footer" class="text-zinc-100">0</span></span>
        <span class="text-zinc-100 animate-pulse">Press [ESC] to Exit</span>
        <span class="text-zinc-500">Best: <span id="mem-best-footer" class="text-amber-500">—</span></span>
      </div>
    </div>
  </div>
</div>

<script>
  type GameState = 'idle' | 'playing' | 'gameover';
  type CardState = 'down' | 'up' | 'matched';

  interface Card {
    emoji: string;
    state: CardState;
  }

  const ALL_EMOJI = ['🎮', '🚀', '🔥', '💎', '🎯', '🧩', '⚡', '🎪', '🌟', '🎲', '🏆', '🎸'];
  const GRID_SIZE = 4;
  const TOTAL_CARDS = GRID_SIZE * GRID_SIZE;
  const PAIR_COUNT = TOTAL_CARDS / 2;

  let cards: Card[] = [];
  let cursorIndex = 0;
  let moves = 0;
  let matchedCount = 0;
  let firstFlip: number | null = null;
  let secondFlip: number | null = null;
  let lockInput = false;
  let gameState: GameState = 'idle';
  let highScore: number | null = (() => {
    const v = localStorage.getItem('mem-highscore');
    return v !== null ? parseInt(v, 10) : null;
  })();

  const modalEl = document.getElementById('mem-modal')!;
  const gridEl = document.getElementById('mem-grid')!;
  const overlayEl = document.getElementById('mem-overlay')!;
  const overlayTextEl = document.getElementById('mem-overlay-text')!;
  const movesFooterEl = document.getElementById('mem-moves-footer')!;
  const bestFooterEl = document.getElementById('mem-best-footer')!;

  let cells: HTMLDivElement[] = [];

  function updateBestDisplay() {
    bestFooterEl.textContent = highScore !== null ? String(highScore) : '—';
  }
  updateBestDisplay();

  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function pickEmoji(): string[] {
    const picked = shuffle(ALL_EMOJI).slice(0, PAIR_COUNT);
    return shuffle([...picked, ...picked]);
  }

  function buildGrid() {
    cells = [];
    const container = document.createElement('div');
    container.style.display = 'grid';
    container.style.gridTemplateColumns = `repeat(${GRID_SIZE}, 60px)`;
    container.style.gap = '4px';

    for (let i = 0; i < TOTAL_CARDS; i++) {
      const cell = document.createElement('div');
      cell.style.width = '60px';
      cell.style.height = '60px';
      cell.style.display = 'flex';
      cell.style.alignItems = 'center';
      cell.style.justifyContent = 'center';
      cell.style.fontSize = '1.5rem';
      cell.style.lineHeight = '1';
      cell.style.cursor = 'default';
      cell.style.boxSizing = 'border-box';
      cell.style.border = '2px solid transparent';
      cells.push(cell);
      container.appendChild(cell);
    }

    gridEl.innerHTML = '';
    gridEl.appendChild(container);
  }

  function render() {
    for (let i = 0; i < TOTAL_CARDS; i++) {
      const cell = cells[i];
      const card = cards[i];

      // Background and content based on card state
      if (card.state === 'down') {
        cell.style.backgroundColor = '#27272a'; // zinc-800
        cell.textContent = '';
      } else if (card.state === 'up') {
        cell.style.backgroundColor = '#000000';
        cell.textContent = card.emoji;
      } else {
        // matched
        cell.style.backgroundColor = '#064e3b'; // emerald-900
        cell.textContent = card.emoji;
        cell.style.opacity = '0.7';
      }

      // Cursor highlight
      if (i === cursorIndex && gameState === 'playing') {
        cell.style.borderColor = '#52525b'; // zinc-600
      } else {
        cell.style.borderColor = 'transparent';
      }

      // Reset opacity for non-matched
      if (card.state !== 'matched') {
        cell.style.opacity = '1';
      }
    }

    movesFooterEl.textContent = String(moves);
  }

  function showOverlay(textLines: string[]) {
    overlayEl.classList.remove('hidden');
    overlayTextEl.innerHTML = textLines
      .map(l => `<p class="text-zinc-100 text-xs font-bold uppercase tracking-widest">${l}</p>`)
      .join('');
  }

  function hideOverlay() {
    overlayEl.classList.add('hidden');
    overlayTextEl.innerHTML = '';
  }

  function checkMatch() {
    if (firstFlip === null || secondFlip === null) return;

    moves++;
    const a = firstFlip;
    const b = secondFlip;

    if (cards[a].emoji === cards[b].emoji) {
      cards[a].state = 'matched';
      cards[b].state = 'matched';
      matchedCount += 2;
      firstFlip = null;
      secondFlip = null;
      lockInput = false;
      render();

      if (matchedCount === TOTAL_CARDS) {
        endGame();
      }
    } else {
      lockInput = true;
      setTimeout(() => {
        cards[a].state = 'down';
        cards[b].state = 'down';
        firstFlip = null;
        secondFlip = null;
        lockInput = false;
        render();
      }, 800);
    }

    render();
  }

  function flipCard(index: number) {
    if (lockInput) return;
    if (cards[index].state !== 'down') return;
    if (firstFlip === index) return;

    cards[index].state = 'up';

    if (firstFlip === null) {
      firstFlip = index;
      render();
    } else {
      secondFlip = index;
      render();
      checkMatch();
    }
  }

  function endGame() {
    gameState = 'gameover';
    if (highScore === null || moves < highScore) {
      highScore = moves;
      localStorage.setItem('mem-highscore', String(highScore));
      updateBestDisplay();
    }
    showOverlay([`Complete! ${moves} moves`, 'Press [ENTER] to retry']);
  }

  function startGame() {
    gameState = 'playing';
    hideOverlay();
    const emojis = pickEmoji();
    cards = emojis.map(e => ({ emoji: e, state: 'down' as CardState }));
    cursorIndex = 0;
    moves = 0;
    matchedCount = 0;
    firstFlip = null;
    secondFlip = null;
    lockInput = false;
    buildGrid();
    render();
  }

  function isModalVisible() {
    return !modalEl.classList.contains('hidden');
  }

  function moveCursor(dx: number, dy: number) {
    const col = cursorIndex % GRID_SIZE;
    const row = Math.floor(cursorIndex / GRID_SIZE);
    const newCol = Math.max(0, Math.min(GRID_SIZE - 1, col + dx));
    const newRow = Math.max(0, Math.min(GRID_SIZE - 1, row + dy));
    cursorIndex = newRow * GRID_SIZE + newCol;
  }

  function handleMemoryKeys(e: KeyboardEvent) {
    if (!isModalVisible()) return;

    const key = e.key.toLowerCase();

    if (key === 'escape') {
      (window as any).toggleMemory();
      e.preventDefault();
      e.stopPropagation();
      return;
    }

    if (key === 'enter') {
      if (gameState === 'idle' || gameState === 'gameover') {
        startGame();
        e.preventDefault();
        e.stopPropagation();
        return;
      }
    }

    if (gameState !== 'playing') return;

    let handled = true;

    if (key === 'arrowleft') {
      moveCursor(-1, 0);
    } else if (key === 'arrowright') {
      moveCursor(1, 0);
    } else if (key === 'arrowup') {
      moveCursor(0, -1);
    } else if (key === 'arrowdown') {
      moveCursor(0, 1);
    } else if (key === 'enter' || key === ' ') {
      flipCard(cursorIndex);
    } else {
      handled = false;
    }

    if (handled) {
      render();
      e.preventDefault();
      e.stopPropagation();
    }
  }

  document.addEventListener('keydown', handleMemoryKeys, true);

  (window as any).toggleMemory = function () {
    const isHidden = modalEl.classList.contains('hidden');
    modalEl.classList.toggle('hidden');
    modalEl.classList.toggle('flex');
    document.body.style.overflow = isHidden ? 'hidden' : '';

    if (isHidden) {
      cards = Array.from({ length: TOTAL_CARDS }, () => ({ emoji: '', state: 'down' as CardState }));
      cursorIndex = 0;
      moves = 0;
      matchedCount = 0;
      firstFlip = null;
      secondFlip = null;
      lockInput = false;
      gameState = 'idle';
      buildGrid();
      render();
      showOverlay(['[ mem_v1.0 ]', 'Press [ENTER] to start']);
    } else {
      gameState = 'idle';
    }
  };
</script>
