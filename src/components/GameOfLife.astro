<!-- No frontmatter needed -->

<canvas id="gol-canvas" class="fixed inset-0 z-0 pointer-events-none hidden"></canvas>

<script>
  const canvas = document.getElementById('gol-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  const CELL_SIZE = 5;
  const ALIVE_COLOR = 'rgba(16, 185, 129, 0.4)'; // emerald-500 at 40%
  const TICK_MS = 120;
  const RESPAWN_THRESHOLD = 0.02;
  const INITIAL_DENSITY = 0.18;

  let cols = 0;
  let rows = 0;
  let grid: Uint8Array;
  let nextGrid: Uint8Array;
  let running = false;
  let interval: ReturnType<typeof setInterval> | null = null;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    const newCols = Math.ceil(canvas.width / CELL_SIZE);
    const newRows = Math.ceil(canvas.height / CELL_SIZE);

    if (newCols !== cols || newRows !== rows) {
      const oldGrid = grid;
      const oldCols = cols;
      const oldRows = rows;
      cols = newCols;
      rows = newRows;
      grid = new Uint8Array(cols * rows);
      nextGrid = new Uint8Array(cols * rows);

      if (oldGrid) {
        for (let y = 0; y < Math.min(oldRows, rows); y++) {
          for (let x = 0; x < Math.min(oldCols, cols); x++) {
            grid[y * cols + x] = oldGrid[y * oldCols + x];
          }
        }
      }
    }
  }

  function seedRandom(density: number) {
    for (let i = 0; i < grid.length; i++) {
      grid[i] = Math.random() < density ? 1 : 0;
    }
  }

  function countNeighbors(x: number, y: number): number {
    let count = 0;
    for (let dy = -1; dy <= 1; dy++) {
      for (let dx = -1; dx <= 1; dx++) {
        if (dx === 0 && dy === 0) continue;
        const nx = (x + dx + cols) % cols;
        const ny = (y + dy + rows) % rows;
        count += grid[ny * cols + nx];
      }
    }
    return count;
  }

  function step() {
    let alive = 0;
    for (let y = 0; y < rows; y++) {
      for (let x = 0; x < cols; x++) {
        const i = y * cols + x;
        const n = countNeighbors(x, y);
        const cell = grid[i];
        if (cell) {
          nextGrid[i] = (n === 2 || n === 3) ? 1 : 0;
        } else {
          nextGrid[i] = (n === 3) ? 1 : 0;
        }
        alive += nextGrid[i];
      }
    }

    if (alive / grid.length < RESPAWN_THRESHOLD) {
      const rx = Math.floor(Math.random() * (cols - 20));
      const ry = Math.floor(Math.random() * (rows - 20));
      for (let dy = 0; dy < 20; dy++) {
        for (let dx = 0; dx < 20; dx++) {
          if (Math.random() < 0.3) {
            nextGrid[(ry + dy) * cols + (rx + dx)] = 1;
          }
        }
      }
    }

    const tmp = grid;
    grid = nextGrid;
    nextGrid = tmp;
  }

  function render() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.shadowColor = 'rgb(16, 185, 129)';
    ctx.shadowBlur = 12;
    ctx.fillStyle = ALIVE_COLOR;

    for (let y = 0; y < rows; y++) {
      for (let x = 0; x < cols; x++) {
        if (grid[y * cols + x]) {
          ctx.fillRect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE - 1, CELL_SIZE - 1);
        }
      }
    }

    ctx.shadowBlur = 0;
  }

  function start() {
    canvas.classList.remove('hidden');
    resize();
    seedRandom(INITIAL_DENSITY);
    render();
    running = true;
    if (interval) clearInterval(interval);
    interval = setInterval(() => { step(); render(); }, TICK_MS);
  }

  function stop() {
    running = false;
    if (interval) { clearInterval(interval); interval = null; }
    canvas.classList.add('hidden');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
  }

  (window as any).toggleLife = function () {
    if (running) { stop(); } else { start(); }
  };

  window.addEventListener('resize', () => {
    if (running) { resize(); render(); }
  });

  document.addEventListener('visibilitychange', () => {
    if (!running) return;
    if (document.hidden) {
      if (interval) { clearInterval(interval); interval = null; }
    } else {
      interval = setInterval(() => { step(); render(); }, TICK_MS);
    }
  });
</script>
