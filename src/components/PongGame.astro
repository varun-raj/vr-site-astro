<!-- No frontmatter needed -->

<div id="pong-modal" class="fixed inset-0 z-[300] bg-black/60 backdrop-blur-[2px] hidden items-center justify-center p-6 text-zinc-400 font-mono">
  <div class="w-full max-w-lg border-2 border-zinc-100 bg-black p-1 shadow-2xl">
    <div class="border border-zinc-100/30 p-4 space-y-4 relative">
      <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-black px-4 text-xs font-bold uppercase tracking-[0.2em] text-zinc-100">
        [ pong_v1.0 ]
      </div>

      <div class="flex justify-center pt-2">
        <canvas id="pong-canvas" class="border border-zinc-100/20"></canvas>
      </div>

      <div id="pong-overlay" class="absolute inset-0 flex items-center justify-center pointer-events-none hidden">
        <div id="pong-overlay-text" class="text-center space-y-2 bg-black/80 px-6 py-4"></div>
      </div>

      <div class="pt-2 border-t border-zinc-100/20 flex justify-between items-center text-[10px] uppercase font-bold">
        <span class="text-zinc-500">Player: <span id="pong-p-score" class="text-emerald-500">0</span></span>
        <span class="text-zinc-100 animate-pulse">Press [ESC] to Exit</span>
        <span class="text-zinc-500">CPU: <span id="pong-c-score" class="text-red-500">0</span></span>
      </div>
    </div>
  </div>
</div>

<script>
  type GameState = 'idle' | 'playing' | 'gameover';

  // Board dimensions
  const DESKTOP_W = 400;
  const DESKTOP_H = 300;
  const MOBILE_W = 320;
  const MOBILE_H = 240;

  // Paddles
  const PADDLE_W = 10;
  const PADDLE_H = 60;
  const PADDLE_MARGIN = 15;
  const PLAYER_SPEED = 5;
  const CPU_SPEED = 3.5;
  const PLAYER_COLOR = '#10b981'; // emerald-500
  const CPU_COLOR = '#ef4444';    // red-500

  // Ball
  const BALL_SIZE = 8;
  const BALL_COLOR = '#f4f4f5'; // zinc-100
  const INITIAL_BALL_SPEED = 5;
  const SPEED_INCREMENT = 0.5;
  const WIN_SCORE = 5;

  // State
  let gameState: GameState = 'idle';
  let playerScore = 0;
  let cpuScore = 0;

  let canvasW = 0;
  let canvasH = 0;
  let playerY = 0;
  let cpuY = 0;
  let ballX = 0;
  let ballY = 0;
  let ballDX = 0;
  let ballDY = 0;
  let ballSpeed = INITIAL_BALL_SPEED;
  let animFrame: number | null = null;
  let countdown = 0;
  let countdownStart = 0;
  let pendingBallDir = false; // toward player?

  // Keys held
  const keysDown: Set<string> = new Set();

  // DOM
  const modalEl = document.getElementById('pong-modal')!;
  const canvasEl = document.getElementById('pong-canvas') as HTMLCanvasElement;
  const ctx = canvasEl.getContext('2d')!;
  const overlayEl = document.getElementById('pong-overlay')!;
  const overlayTextEl = document.getElementById('pong-overlay-text')!;
  const pScoreEl = document.getElementById('pong-p-score')!;
  const cScoreEl = document.getElementById('pong-c-score')!;

  function getBoardSize(): [number, number] {
    return window.innerWidth >= 768 ? [DESKTOP_W, DESKTOP_H] : [MOBILE_W, MOBILE_H];
  }

  function setupCanvas() {
    [canvasW, canvasH] = getBoardSize();
    canvasEl.width = canvasW;
    canvasEl.height = canvasH;
    canvasEl.style.width = `${canvasW}px`;
    canvasEl.style.height = `${canvasH}px`;
  }

  function resetPositions() {
    playerY = (canvasH - PADDLE_H) / 2;
    cpuY = (canvasH - PADDLE_H) / 2;
  }

  function resetBall(towardPlayer: boolean) {
    ballX = canvasW / 2;
    ballY = canvasH / 2;
    const angle = (Math.random() - 0.5) * Math.PI / 3; // -30 to +30 degrees
    const dir = towardPlayer ? -1 : 1;
    ballDX = ballSpeed * Math.cos(angle) * dir;
    ballDY = ballSpeed * Math.sin(angle);
  }

  function updateScoreDisplay() {
    pScoreEl.textContent = String(playerScore);
    cScoreEl.textContent = String(cpuScore);
  }

  function showOverlay(textLines: string[]) {
    overlayEl.classList.remove('hidden');
    overlayTextEl.innerHTML = textLines
      .map(l => `<p class="text-zinc-100 text-xs font-bold uppercase tracking-widest">${l}</p>`)
      .join('');
  }

  function hideOverlay() {
    overlayEl.classList.add('hidden');
    overlayTextEl.innerHTML = '';
  }

  function isModalVisible() {
    return !modalEl.classList.contains('hidden');
  }

  function startCountdown(towardPlayer: boolean) {
    countdown = 3;
    countdownStart = performance.now();
    pendingBallDir = towardPlayer;
    ballX = canvasW / 2;
    ballY = canvasH / 2;
    ballDX = 0;
    ballDY = 0;
  }

  function update() {
    // Handle countdown
    if (countdown > 0) {
      const elapsed = performance.now() - countdownStart;
      const remaining = 3 - Math.floor(elapsed / 1000);
      if (remaining !== countdown) countdown = remaining;
      if (countdown <= 0) {
        countdown = 0;
        resetBall(pendingBallDir);
      }
      return;
    }

    // Move player paddle
    if (keysDown.has('arrowup') || keysDown.has('w')) {
      playerY = Math.max(0, playerY - PLAYER_SPEED);
    }
    if (keysDown.has('arrowdown') || keysDown.has('s')) {
      playerY = Math.min(canvasH - PADDLE_H, playerY + PLAYER_SPEED);
    }

    // CPU AI: follow ball with slight delay
    const cpuCenter = cpuY + PADDLE_H / 2;
    if (ballY < cpuCenter - 5) {
      cpuY = Math.max(0, cpuY - CPU_SPEED);
    } else if (ballY > cpuCenter + 5) {
      cpuY = Math.min(canvasH - PADDLE_H, cpuY + CPU_SPEED);
    }

    // Move ball
    ballX += ballDX;
    ballY += ballDY;

    // Top/bottom wall collisions
    if (ballY - BALL_SIZE / 2 <= 0) {
      ballY = BALL_SIZE / 2;
      ballDY = Math.abs(ballDY);
    }
    if (ballY + BALL_SIZE / 2 >= canvasH) {
      ballY = canvasH - BALL_SIZE / 2;
      ballDY = -Math.abs(ballDY);
    }

    // Player paddle collision (left side)
    const playerPaddleRight = PADDLE_MARGIN + PADDLE_W;
    if (
      ballDX < 0 &&
      ballX - BALL_SIZE / 2 <= playerPaddleRight &&
      ballX - BALL_SIZE / 2 >= PADDLE_MARGIN &&
      ballY >= playerY &&
      ballY <= playerY + PADDLE_H
    ) {
      const hitPos = (ballY - playerY) / PADDLE_H; // 0 to 1
      const angle = (hitPos - 0.5) * Math.PI / 3;  // -30 to +30 degrees
      const speed = Math.sqrt(ballDX * ballDX + ballDY * ballDY);
      ballDX = speed * Math.cos(angle);
      ballDY = speed * Math.sin(angle);
      ballX = playerPaddleRight + BALL_SIZE / 2;
    }

    // CPU paddle collision (right side)
    const cpuPaddleLeft = canvasW - PADDLE_MARGIN - PADDLE_W;
    if (
      ballDX > 0 &&
      ballX + BALL_SIZE / 2 >= cpuPaddleLeft &&
      ballX + BALL_SIZE / 2 <= cpuPaddleLeft + PADDLE_W &&
      ballY >= cpuY &&
      ballY <= cpuY + PADDLE_H
    ) {
      const hitPos = (ballY - cpuY) / PADDLE_H;
      const angle = (hitPos - 0.5) * Math.PI / 3;
      const speed = Math.sqrt(ballDX * ballDX + ballDY * ballDY);
      ballDX = -speed * Math.cos(angle);
      ballDY = speed * Math.sin(angle);
      ballX = cpuPaddleLeft - BALL_SIZE / 2;
    }

    // Ball past left edge — CPU scores
    if (ballX + BALL_SIZE / 2 < 0) {
      cpuScore++;
      ballSpeed += SPEED_INCREMENT;
      updateScoreDisplay();
      if (cpuScore >= WIN_SCORE) {
        endGame(false);
      } else {
        startCountdown(true);
      }
      return;
    }

    // Ball past right edge — Player scores
    if (ballX - BALL_SIZE / 2 > canvasW) {
      playerScore++;
      ballSpeed += SPEED_INCREMENT;
      updateScoreDisplay();
      if (playerScore >= WIN_SCORE) {
        endGame(true);
      } else {
        startCountdown(false);
      }
      return;
    }
  }

  function draw() {
    // Clear
    ctx.fillStyle = '#000000';
    ctx.fillRect(0, 0, canvasW, canvasH);

    // Center dashed line
    ctx.strokeStyle = '#27272a'; // zinc-800
    ctx.lineWidth = 2;
    ctx.setLineDash([6, 6]);
    ctx.beginPath();
    ctx.moveTo(canvasW / 2, 0);
    ctx.lineTo(canvasW / 2, canvasH);
    ctx.stroke();
    ctx.setLineDash([]);

    // Scores at top of canvas
    ctx.fillStyle = '#71717a'; // zinc-500
    ctx.font = 'bold 32px monospace';
    ctx.textAlign = 'center';
    ctx.fillText(String(playerScore), canvasW / 4, 40);
    ctx.fillText(String(cpuScore), (canvasW / 4) * 3, 40);

    // Player paddle (left)
    ctx.fillStyle = PLAYER_COLOR;
    ctx.fillRect(PADDLE_MARGIN, playerY, PADDLE_W, PADDLE_H);

    // CPU paddle (right)
    ctx.fillStyle = CPU_COLOR;
    ctx.fillRect(canvasW - PADDLE_MARGIN - PADDLE_W, cpuY, PADDLE_W, PADDLE_H);

    // Ball (square) — hide during countdown
    if (countdown <= 0) {
      ctx.fillStyle = BALL_COLOR;
      ctx.fillRect(ballX - BALL_SIZE / 2, ballY - BALL_SIZE / 2, BALL_SIZE, BALL_SIZE);
    }

    // Countdown display
    if (countdown > 0) {
      ctx.fillStyle = '#f4f4f5';
      ctx.font = 'bold 48px monospace';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(String(countdown), canvasW / 2, canvasH / 2);
      ctx.textBaseline = 'alphabetic';
    }
  }

  function gameLoop() {
    if (gameState !== 'playing') return;
    update();
    draw();
    animFrame = requestAnimationFrame(gameLoop);
  }

  function endGame(playerWon: boolean) {
    gameState = 'gameover';
    if (animFrame !== null) { cancelAnimationFrame(animFrame); animFrame = null; }
    if (playerWon) {
      showOverlay(['You Win!', 'Press [ENTER] to retry']);
    } else {
      showOverlay(['CPU Wins!', 'Press [ENTER] to retry']);
    }
    draw();
  }

  function startGame() {
    gameState = 'playing';
    hideOverlay();
    playerScore = 0;
    cpuScore = 0;
    ballSpeed = INITIAL_BALL_SPEED;
    updateScoreDisplay();
    setupCanvas();
    resetPositions();
    resetBall(false);
    draw();
    if (animFrame !== null) cancelAnimationFrame(animFrame);
    animFrame = requestAnimationFrame(gameLoop);
  }

  function handlePongKeys(e: KeyboardEvent) {
    if (!isModalVisible()) return;

    const key = e.key.toLowerCase();

    if (key === 'escape') {
      (window as any).togglePong();
      e.preventDefault();
      e.stopPropagation();
      return;
    }

    if (key === 'enter') {
      if (gameState === 'idle' || gameState === 'gameover') {
        startGame();
      }
      e.preventDefault();
      e.stopPropagation();
      return;
    }

    if (gameState !== 'playing') return;

    if (['arrowup', 'arrowdown', 'w', 's'].includes(key)) {
      keysDown.add(key);
      e.preventDefault();
      e.stopPropagation();
    }
  }

  function handlePongKeyUp(e: KeyboardEvent) {
    if (!isModalVisible()) return;
    const key = e.key.toLowerCase();
    keysDown.delete(key);
  }

  document.addEventListener('keydown', handlePongKeys, true);
  document.addEventListener('keyup', handlePongKeyUp, true);

  (window as any).togglePong = function () {
    const isHidden = modalEl.classList.contains('hidden');
    modalEl.classList.toggle('hidden');
    modalEl.classList.toggle('flex');
    document.body.style.overflow = isHidden ? 'hidden' : '';

    if (isHidden) {
      gameState = 'idle';
      playerScore = 0;
      cpuScore = 0;
      ballSpeed = INITIAL_BALL_SPEED;
      updateScoreDisplay();
      setupCanvas();
      resetPositions();
      ballX = canvasW / 2;
      ballY = canvasH / 2;
      draw();
      showOverlay(['[ pong_v1.0 ]', 'Press [ENTER] to start']);
    } else {
      if (animFrame !== null) { cancelAnimationFrame(animFrame); animFrame = null; }
      gameState = 'idle';
      keysDown.clear();
    }
  };

  window.addEventListener('resize', () => {
    if (isModalVisible() && gameState === 'idle') {
      setupCanvas();
      resetPositions();
      ballX = canvasW / 2;
      ballY = canvasH / 2;
      draw();
    }
  });
</script>
